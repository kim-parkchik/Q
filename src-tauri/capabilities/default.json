{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "http:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-mkdir", 
    "fs:allow-copy-file",
    "fs:allow-document-read",
    "fs:allow-document-write",
    "fs:scope-document-recursive",
    "core:path:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://www8.cao.go.jp/chosei/shukujitsu/syukujitsu.csv" },
        { "url": "https://www.houjin-bangou.nta.go.jp/**" },
        { "url": "https://zipcloud.ibsnet.co.jp/**" }
      ]
    }
  ]
}